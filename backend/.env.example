# ============================================================
#  Backend .env — copy this to backend/.env and fill in values
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=Personal Research Copilot API
APP_ENV=development
LOG_LEVEL=INFO

# ── LLM ──────────────────────────────────────────────────────
LLM_PROVIDER=huggingface
# Qwen/Qwen2.5-7B-Instruct  = default, free, great at JSON (recommended)
# meta-llama/Llama-3.1-8B-Instruct  = strong alternative on HuggingFace free tier
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# Get a free token at: huggingface.co/settings/tokens (Read role is enough)
HUGGINGFACE_API_KEY=

# Other providers (leave blank if not using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

STRICT_LLM_MODE=false
AGENT_RETRY_LIMIT=2
RETRIEVAL_QUERY_EXPANSIONS=3

# ── Citation crawl ────────────────────────────────────────────────────────────
# Auto-indexes papers referenced by papers you open (runs in background thread)
# depth=1: direct references only; depth=2: refs-of-refs; etc.
CITATION_CRAWL_ENABLED=true
CITATION_CRAWL_DEPTH=2
CITATION_CRAWL_MAX_PAPERS=20
RETRIEVAL_CANDIDATE_MULTIPLIER=4

# ── API auth ─────────────────────────────────────────────────
REQUIRE_API_KEY=false
BACKEND_API_KEY=
REQUIRE_GRAPH_REVIEW=false

# ── Token / chunk budgets ────────────────────────────────────
MAX_PROMPT_TOKENS=3500
MAX_CHUNKS=6
DEFAULT_CHUNK_SIZE=400
MAX_CHUNK_SIZE=500
CHUNK_OVERLAP=50
PDF_EXTRACT_MAX_PAGES=25

# ── Stage timeouts ────────────────────────────────────────────
FAST_STAGE_TIMEOUT_SECONDS=3
FULL_STAGE_TIMEOUT_SECONDS=30

# ── Queue / caches ────────────────────────────────────────────
QUEUE_MAX_SIZE=200
QUEUE_WORKER_COUNT=2
ANALYSIS_CACHE_TTL_SECONDS=21600
ANALYSIS_CACHE_MAX_ENTRIES=4000
EMBEDDING_CACHE_TTL_SECONDS=86400
EMBEDDING_CACHE_MAX_ENTRIES=10000
METADATA_CACHE_TTL_SECONDS=21600
METADATA_CACHE_MAX_ENTRIES=10000

# ── FAISS ─────────────────────────────────────────────────────
# Must match embedding model output dimension.
#   deterministic fallback (no OpenAI key, HuggingFace) -> 256
#   text-embedding-3-small (with OpenAI key)             -> 1536
# DELETE backend/data/faiss/ before changing this on an existing install.
FAISS_DIMENSION=256
FAISS_DATA_DIR=backend/data/faiss
GRAPH_REVIEW_DATA_PATH=backend/data/reviews/reviews.json

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=researchcopilot

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=["*"]
