# Copy this file to docker/.env and adjust values.
# ── LLM ──────────────────────────────────────────
LLM_PROVIDER=huggingface
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGINGFACE_API_KEY=
# Other providers (leave blank if not using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Neo4j ────────────────────────────────────────
NEO4J_DB_PASSWORD=researchcopilot

# ── Backend ──────────────────────────────────────
STRICT_LLM_MODE=false
REQUIRE_API_KEY=false
BACKEND_API_KEY=
QUEUE_MAX_SIZE=200
QUEUE_WORKER_COUNT=2
